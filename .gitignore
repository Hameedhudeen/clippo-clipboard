# Internal planning and local reference material
/tasks.md
/references/
.agents/
.codex/

# Validation logs generated on target hosts.
# Keep arbitrary target-host logs ignored, but allow curated evidence files that
# are intentionally reviewed and safe to publish.
/docs/validation/*.md
!/docs/validation/README.md
!/docs/validation/TEMPLATE.md
!/docs/validation/evidence-*.md
!/docs/validation/release-*.md

# Logs and diagnostics
*.log
logs/
diagnostics/

# Editors and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local environment
.env
.env.*
!.env.example
