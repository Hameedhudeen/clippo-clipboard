# Rust
/target/
**/*.rs.bk

# Swift / Xcode
.build/
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate

# .NET / Windows
bin/
obj/
*.user
*.suo
.vs/

# Linux packaging
/dist/
*.AppImage
*.deb
*.rpm
